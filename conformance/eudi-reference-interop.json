{
  "schema": "elevenid.eudi-reference-interop/v1",
  "review_cadence": "monthly",
  "components": {
    "wallet_tester": {
      "repository": "https://github.com/eu-digital-identity-wallet/eudi-app-web-wallet-tester-py.git",
      "release": "v0.5.2",
      "commit": "7605672f5a4b22c5f867490cd9b4889e1ec5f748",
      "image": "ghcr.io/eu-digital-identity-wallet/eudi-app-web-wallet-tester-py@sha256:d2978c7a9bb29b00f8c202d054b8a9a4ec8e9addf2e16314f3ed06426aef19be"
    },
    "verifier_endpoint": {
      "repository": "https://github.com/eu-digital-identity-wallet/eudi-srv-verifier-endpoint.git",
      "commit": "de66a3e311ed413838de240affef4511072b8687",
      "image": "ghcr.io/eu-digital-identity-wallet/eudi-srv-verifier-endpoint@sha256:0687ad0bf9c315d64d7cdae1751c8795c2410848f2299adeaaf1c39305366711"
    },
    "wallet_kit": {
      "implementation": "ElevenID HTTP test facade over official EUDI JVM libraries",
      "build": {
        "dockerfile": "services/eudi-wallet-harness/Dockerfile",
        "builder_image": "docker.io/library/gradle:8.11-jdk17@sha256:91d559b8d55f522de5bc6882f73bcedc4e2cc7b0a58e839a9fa0ed95811a988d",
        "runtime_image": "docker.io/library/eclipse-temurin:17-jre@sha256:92999aea37688157a53a40bfcb187c30f317422e028045fd5fc5c548fde9e626",
        "public_url_bridge_image": "docker.io/alpine/socat:1.8.0.3@sha256:a26f4bcee25ad4a4096ce91e596c0a2fffcbb51f7fd198dd87a5c86eae66f0e1",
        "dependency_lock": "services/eudi-wallet-harness/gradle.lockfile",
        "dependency_verification": "services/eudi-wallet-harness/gradle/verification-metadata.xml"
      },
      "libraries": {
        "oid4vp": {
          "repository": "https://github.com/eu-digital-identity-wallet/eudi-lib-jvm-openid4vp-kt.git",
          "release": "v0.12.3",
          "version": "0.12.3",
          "commit": "ff2af51189e6e9f014d6c7eab65690f99652457e",
          "maven_coordinate": "eu.europa.ec.eudi:eudi-lib-jvm-openid4vp-kt:0.12.3"
        },
        "oid4vci": {
          "repository": "https://github.com/eu-digital-identity-wallet/eudi-lib-jvm-openid4vci-kt.git",
          "release": "v0.9.1",
          "version": "0.9.1",
          "commit": "ee36d07cd3f78afdd3e7016b3be1f6022f85ef92",
          "maven_coordinate": "eu.europa.ec.eudi:eudi-lib-jvm-openid4vci-kt:0.9.1"
        },
        "sd_jwt": {
          "repository": "https://github.com/eu-digital-identity-wallet/eudi-lib-jvm-sdjwt-kt.git",
          "release": "v0.18.0",
          "version": "0.18.0",
          "commit": "c81ba73c62bae6194fd8ab6e3c5d153b8ed0fc39",
          "maven_coordinate": "eu.europa.ec.eudi:eudi-lib-jvm-sdjwt-kt:0.18.0"
        }
      }
    }
  },
  "coverage": {
    "issuance": ["sd_jwt_vc", "mso_mdoc"],
    "presentation": ["sd_jwt_vc"],
    "request_object_trust": ["signed_jar_x509_hash_pkix"],
    "response_mode": ["direct_post.jwt"],
    "negative": ["missing_holder_binding_key"]
  },
  "required_evidence": {
    "eudi.oid4vci.sd-jwt-issuance.v1": {
      "claims": ["issuance:sd_jwt_vc"]
    },
    "eudi.oid4vci.mdoc-issuance.v1": {
      "claims": ["issuance:mso_mdoc"]
    },
    "eudi.oid4vp.haip.resolve-dispatch.v1": {
      "claims": [
        "presentation:sd_jwt_vc",
        "request_object_trust:signed_jar_x509_hash_pkix",
        "response_mode:direct_post.jwt"
      ]
    },
    "eudi.sd-jwt.missing-holder-binding-key.v1": {
      "claims": ["negative:missing_holder_binding_key"]
    }
  },
  "compatibility_only": {
    "presentation": ["mso_mdoc"]
  },
  "planned_coverage": {
    "presentation": ["mso_mdoc_device_response"],
    "negative": ["replayed_response", "invalid_signature", "expired_or_invalid_request"]
  },
  "limitations": {
    "mso_mdoc_presentation": {
      "status": "not_officially_exercised",
      "reason": "The compatibility endpoint passes issuer-signed mDoc bytes through; it does not yet construct the ISO 18013-5 device response and device authentication required by the official OID4VP flow.",
      "owner": "ElevenID interoperability",
      "review_date": "2026-10-01"
    },
    "oid4vp_negative_vectors": {
      "status": "planned",
      "reason": "Replay, tampered-signature, and expired-request vectors are not claimed until they execute against the production verifier path.",
      "owner": "ElevenID interoperability",
      "review_date": "2026-10-01"
    }
  },
  "target": "digest-pinned EUDI components against the public Marty gateway and normal issuer/verifier flows"
}
