# Environment variables for running integration tests from the host.
# The Docker Compose stack exposes services on port 28xxx (internal 8xxx + 20000).
#
# Usage:
#   set -a && source .env.test && set +a
#   pytest tests/integration/gateway/ -q
#
# Or inline:
#   env $(cat .env.test | grep -v '^#' | xargs) pytest tests/integration/gateway/ -q

GATEWAY_URL=http://localhost:28000
AUTH_SERVICE_URL=http://localhost:28001
ORGANIZATION_SERVICE_URL=http://localhost:28002
KEYCLOAK_LOCAL_URL=http://localhost:8180
